# Copy to `.env` (gitignored) and fill in. Values are sourced by bin/build.sh
# and substituted into each SKILL.md as `${NAME}` placeholders before zipping.
# The committed SKILL.md keeps the placeholders so secrets don't leak into the
# public repo.

# Pitchside host (public base URL, including scheme).
# Used by the `footy` skill to print the post-match tally URL.
PITCHSIDE_HOST=https://pitchside.example.org
